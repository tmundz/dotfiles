# Never commit secrets, histories, generated state, or app profiles.
.ssh/
.gnupg/
.pki/
.cache/
.local/
.histfile
.zcompdump*
.wget-hsts
.pulse-cookie
.emulator_console_auth_token

# Agent/app auth and state.
.claude/
.codex/auth.json
.codex/history.jsonl
.codex/log*/
.codex/logs*.sqlite*
.codex/state*.sqlite*
.codex/shell_snapshots/
.codex/.tmp/
.claude.json*
.gemini/

# Browser and Electron app profiles.
.config/chromium/
.config/BraveSoftware/
.config/Code/
.config/discord/
.config/obsidian/
.config/Caido/
.config/Electron/

# Tool credentials/state.
.config/ngrok/
.config/interactsh-client/
.android/adbkey*
.android/debug.keystore*
.steam/

# Build/dependency output.
node_modules/
target/
dist/
build/
__pycache__/
*.pyc

# Playwright
test-results/
playwright-report/
blob-report/
playwright/.cache/
playwright/.auth/
